# Copy this file to email-backup.toml and adjust the values.

# By default the tool keeps its Maildir inside this repository.
maildir_path = "./data/maildir"

# Examples:
# restic_repo = "/Volumes/backup/restic-mail"
# restic_repo = "b2:my-bucket:mail-history"
restic_repo = "b2:your-bucket-name:backup-folder"

# Store manifests, reports, locks, and logs in a sibling subdirectory.
state_dir = "./data/state"

# How many days old a message must be before disappearance or mutation is treated as suspicious.
immutability_days = 30

# How many sample findings to include in the text report.
report_sample_limit = 20

# Ignore folders that are expected to churn.
ignore_mailbox_regex = '(^|[/.])(Trash|Junk|Spam|Drafts)([/.]|$)'

# Run "restic check" every N days. Set to 0 to disable.
restic_check_interval_days = 7

# Set to false if you do not want to back up the state directory on every run.
restic_include_state_dir = true

# By default the tool uses a dedicated local mbsync config and one channel.
mbsync_command = ["mbsync", "-c", "./mbsyncrc", "mail-backup"]
restic_command = ["restic"]

# Extra arguments for "restic backup" and "restic check".
restic_backup_args = ["--tag", "mail-backup"]
restic_check_args = ["--read-data-subset=5%"]

# Optional hook for alerts. The report body is sent on stdin.
# The command runs with "bash -c" semantics.
# These variables are also set for the command:
#   EMAIL_BACKUP_STATUS
#   EMAIL_BACKUP_ALERT_SUBJECT
#   EMAIL_BACKUP_ALERT_BODY
#
# Example mail alert:
# alert_command = 'mail -s "$EMAIL_BACKUP_ALERT_SUBJECT" you@example.com'
#
# Example Telegram alert:
# alert_command = 'curl -fsS -X POST "https://api.telegram.org/bot<token>/sendMessage" -d chat_id="<chat-id>" --data-urlencode text@"-"'
alert_command = ""

[env]
# Prefer a password file or password command over inline secrets.
RESTIC_PASSWORD_FILE = "./data/restic/password"

# Optional cloud credentials:
# B2_ACCOUNT_ID = "..."
# B2_ACCOUNT_KEY = "..."
